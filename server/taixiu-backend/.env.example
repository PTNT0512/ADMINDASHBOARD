PORT=18082
HOST=0.0.0.0
WS_PATH=/websocket
ENABLE_WEB_CLIENT=true
WEB_BUILD_DIR=../../client/build/web-mobile
MONGODB_URI=mongodb://127.0.0.1:27017/taixiu_dev
DEFAULT_USER_COIN=1000000000
SESSION_HISTORY_LIMIT=100
BET_DURATION_DOUBLE=60
RESULT_DURATION_DOUBLE=15
BET_DURATION_MD5=55
RESULT_DURATION_MD5=15
BET_DURATION_BAUCUA=40
RESULT_DURATION_BAUCUA=10
START_DURATION_XOCDIA=2
BET_DURATION_XOCDIA=20
REFUND_DURATION_XOCDIA=3
RESULT_DURATION_XOCDIA=6
ENABLE_BOT_XOCDIA=true
BOT_BET_MIN_XOCDIA=5000
BOT_BET_MAX_XOCDIA=250000
BOT_BURST_MIN_XOCDIA=1
BOT_BURST_MAX_XOCDIA=3
ENABLE_JACKPOT_DOUBLE=false


# Public endpoint config used by web client route redirects.
# If left empty, backend will use the current browser origin automatically.
PUBLIC_HOST=
PUBLIC_PORT=
PUBLIC_WS_HOST=
PUBLIC_WS_PORT=
PUBLIC_WS_SECURE=0
PUBLIC_API_HOST=
PUBLIC_API_PORT=
PUBLIC_API_SECURE=0
PUBLIC_API_PATH=/api
