# Global shared env file for the whole admin-app system.
# Copy this file to .env and edit only that one file.
# Legacy files (.env.dashboard, .env.center, .env.apibank, server/taixiu-backend/.env)
# are now optional fallback files only.

# -------------------- Common --------------------
MONGODB_URI=mongodb://127.0.0.1:27017/lasvegas
JWT_SECRET=change-this-jwt-secret
ENABLE_UPDATER_IN_DEV=0
NTBA_FIX_350=1
STARTUP_STAGGER_MS=2000
MIN_FREE_MEM_MB=150
GITHUB_TOKEN=
GH_TOKEN=
UPDATER_GITHUB_OWNER=PTNT0512
UPDATER_GITHUB_REPO=ADMINDASHBOARD
UPDATER_GITHUB_PRIVATE=0
UPDATER_GITHUB_RELEASE_TYPE=release

# -------------------- Dashboard --------------------
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=55173
API_PORT=4001
GAME_ADMIN_PORT=4001
DASHBOARD_WEB_ONLY=0
DASHBOARD_SERVE_STATIC=0
DASHBOARD_WEB_HOST=127.0.0.1
DASHBOARD_WEB_PORT=4001
DASHBOARD_WEB_DIST_DIR=dist-dashboard
LICENSE_API_URL=http://127.0.0.1:55175
LANDING_PORT=80
CSKH_APP_PORT=3001
WEBGAME_PORT=3005
TAIXIU_BACKEND_HOST=127.0.0.1
TAIXIU_BACKEND_PORT=18082
GAME_AUTH_SECRET=change-this-game-auth-secret

# -------------------- Center --------------------
CENTER_HOST=127.0.0.1
CENTER_PORT=55174
CENTER_API_HOST=127.0.0.1
CENTER_API_PORT=55175
CENTER_LICENSE_API_URL=http://127.0.0.1:55175

CENTER_WEB_HOST=127.0.0.1
CENTER_WEB_PORT=56174
CENTER_WEB_API_HOST=127.0.0.1
CENTER_WEB_API_PORT=56175
CENTER_WEB_DIST_DIR=dist-center
SYSTEM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=

# -------------------- API Bank --------------------
API_BANK_VCB=https://thueapibank.vn/historyapivcbv2
API_BANK_MB=https://thueapibank.vn/historyapimbbankv2
API_BANK_ACB=https://thueapibank.vn/historyapiacbv2
API_BANK_BIDV=https://thueapibank.vn/historyapibidvv2
API_BANK_TPB=https://thueapibank.vn/historyapitpbv2
API_BANK_MSB=https://thueapibank.vn/historyapimsbv2
API_BANK_VPB=https://thueapibank.vn/historyapivpbankv2
API_BANK_OCB=https://thueapibank.vn/historyapiocbv2
API_BANK_TIMO=https://thueapibank.vn/historyapitimov2
API_BANK_VIETIN=https://thueapibank.vn/historyapiviettinv2
API_BANK_SEABANK=https://thueapibank.vn/historyapiseabankv2

# -------------------- TaiXiu Backend --------------------
TAIXIU_APP_HOST=0.0.0.0
TAIXIU_APP_PORT=18082
TAIXIU_WS_PATH=/websocket
TAIXIU_ENABLE_WEB_CLIENT=1
TAIXIU_WEB_BUILD_DIR=../../client/build/web-mobile
TAIXIU_MONGODB_URI=

# Public endpoint used by the web mini-game routes.
# Leave blank to auto-use the current browser origin.
TAIXIU_PUBLIC_HOST=
TAIXIU_PUBLIC_PORT=
TAIXIU_PUBLIC_WS_HOST=
TAIXIU_PUBLIC_WS_PORT=
TAIXIU_PUBLIC_WS_SECURE=0
TAIXIU_PUBLIC_API_HOST=
TAIXIU_PUBLIC_API_PORT=
TAIXIU_PUBLIC_API_SECURE=0
TAIXIU_PUBLIC_API_PATH=/api

# TaiXiu game timings and limits.
DEFAULT_USER_COIN=1000000000
SESSION_HISTORY_LIMIT=100
BET_DURATION_DOUBLE=60
RESULT_DURATION_DOUBLE=15
BET_DURATION_MD5=55
RESULT_DURATION_MD5=15
BET_DURATION_BAUCUA=40
RESULT_DURATION_BAUCUA=10
START_DURATION_XOCDIA=2
BET_DURATION_XOCDIA=20
REFUND_DURATION_XOCDIA=3
RESULT_DURATION_XOCDIA=6
ENABLE_BOT_XOCDIA=true
BOT_BET_MIN_XOCDIA=5000
BOT_BET_MAX_XOCDIA=250000
BOT_BURST_MIN_XOCDIA=1
BOT_BURST_MAX_XOCDIA=3
ENABLE_JACKPOT_DOUBLE=false

